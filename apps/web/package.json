{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    "./components/*": "./src/components/*"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "prisma generate && next build --turbopack",
    "start": "next start",
    "lint": "biome check --write .",
    "check-types": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "db:pull": "dotenv -e .env.local -- prisma db pull",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:resolve": "dotenv -e .env.local -- prisma migrate resolve --applied",
    "db:migrate:status": "dotenv -e .env.local -- prisma migrate status"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "@rollbar/react": "^1.0.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.85.6",
    "@tanstack/react-query-devtools": "^5.85.6",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.15",
    "gsap": "^3.13.0",
    "jotai": "^2.14.0",
    "lucide-react": "^0.542.0",
    "next": "^15.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.0.0",
    "rollbar": "^2.26.5",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@jridgewell/resolve-uri": "^3.1.2",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "dotenv-cli": "^10.0.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.4.41",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.1.12",
    "ts-jest": "^29.2.5",
    "typescript": "5.9.2"
  }
}
