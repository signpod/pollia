{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    "./components/*": "./src/components/*"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "prisma generate && next build --turbopack",
    "build:with-sourcemaps": "prisma generate && next build --turbopack && dotenv -e .env -- node scripts/upload-sourcemaps.cjs",
    "upload-sourcemaps": "dotenv -e .env -- node scripts/upload-sourcemaps.cjs",
    "cold-start": "node scripts/measure-cold-start.cjs",
    "cold-start:compare": "node scripts/compare-cold-start.cjs",
    "chunks:compare": "node scripts/compare-chunks.cjs",
    "start": "next start",
    "lint": "biome check --write --diagnostic-level=error .",
    "check-types": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "db:pull": "dotenv -e .env.local -- prisma db pull",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:resolve": "dotenv -e .env.local -- prisma migrate resolve --applied",
    "db:migrate:status": "dotenv -e .env.local -- prisma migrate status",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@nivo/sankey": "^0.99.0",
    "@notionhq/client": "^2.2.15",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "@rollbar/react": "^1.0.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.85.6",
    "@tanstack/react-query-devtools": "^5.85.6",
    "@tiptap/core": "^3.13.0",
    "@tiptap/extension-placeholder": "^3.13.0",
    "@tiptap/extensions": "^3.13.0",
    "@tiptap/pm": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "elkjs": "^0.11.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.15",
    "gsap": "^3.13.0",
    "input-otp": "^1.4.2",
    "jotai": "^2.14.0",
    "lucide-react": "^0.555.0",
    "next": "15.5.7",
    "next-themes": "^0.4.6",
    "react": "19.1.2",
    "react-day-picker": "^9.11.2",
    "react-dom": "19.1.2",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.66.1",
    "react-intersection-observer": "^10.0.2",
    "react-resizable-panels": "^3.0.6",
    "recharts": "2.15.4",
    "rollbar": "^2.26.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@jridgewell/resolve-uri": "^3.1.2",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "dotenv-cli": "^10.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.4.41",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.1.12",
    "ts-jest": "^29.2.5",
    "typescript": "5.9.2"
  }
}
