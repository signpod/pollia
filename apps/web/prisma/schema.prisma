generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id
  email     String   @unique
  name      String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 관계
  polls         Poll[]         @relation("PollCreator")
  votes         Vote[]
  pollLikes     PollLike[]
  pollBookmarks PollBookmark[]
  fileUploads   FileUpload[]   @relation("FileUploader")

  @@map("users")
}

model Poll {
  id          String      @id @default(cuid())
  title       String
  description String?
  imageUrl    String? @map("image_url")
  type        PollType
  category    PollCategory

  // 투표 기간
  startDate    DateTime
  endDate      DateTime?
  isIndefinite Boolean   @default(false)

  // 여러 선택지 투표 설정
  maxSelections Int? // null이면 단일 선택 (O/X, 좋아요/싫어요)

  // 결과 공개 설정 (확장성)
  showResultsMode ResultMode @default(IMMEDIATE)
  isPublic        Boolean    @default(true)

  // 관계
  creatorId String
  creator   User   @relation("PollCreator", fields: [creatorId], references: [id])
  options   PollOption[]
  votes     Vote[]
  likes     PollLike[]
  bookmarks PollBookmark[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([type])
  @@index([startDate, endDate])
  @@map("polls")
}

model PollOption {
  id          String @id @default(cuid())
  pollId      String @map("poll_id")
  poll        Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  description String
  imageUrl    String? @map("image_url")
  link        String?
  order       Int

  votes Vote[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([pollId, order])
  @@map("poll_options")
}

model Vote {
  id       String @id @default(cuid())
  pollId   String @map("poll_id")
  poll     Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id])
  optionId String @map("option_id")
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  // 같은 사용자가 같은 옵션에 중복 투표 방지
  @@unique([pollId, userId, optionId])
  @@index([pollId, userId])
  @@map("votes")
}

model PollLike {
  id     String @id @default(cuid())
  pollId String @map("poll_id")
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([pollId, userId])
  @@map("poll_likes")
}

model PollBookmark {
  id     String @id @default(cuid())
  pollId String @map("poll_id")
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([pollId, userId])
  @@map("poll_bookmarks")
}

// 파일 업로드 추적 테이블
model FileUpload {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  user             User      @relation("FileUploader", fields: [userId], references: [id])
  
  // 파일 정보
  originalFileName String    @map("original_file_name")
  filePath         String    @map("file_path")
  publicUrl        String    @map("public_url")
  fileSize         Int       @map("file_size")
  mimeType         String    @map("mime_type")
  bucket           String    @default("poll-images")
  
  // 상태 관리
  status           FileStatus @default(TEMPORARY)
  
  // 연결된 엔티티 정보 (확정 시 설정)
  relatedEntityType RelatedEntityType? @map("related_entity_type")
  relatedEntityId   String?            @map("related_entity_id")
  
  // 시간 추적
  createdAt   DateTime  @default(now()) @map("created_at")
  confirmedAt DateTime? @map("confirmed_at")

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([relatedEntityType, relatedEntityId])
  @@map("file_uploads")
}

enum FileStatus {
  TEMPORARY // 임시 업로드 상태
  CONFIRMED // 확정 완료 상태
}

enum RelatedEntityType {
  POLL        // 폴 대표 이미지
  POLL_OPTION // 폴 옵션 이미지
}

enum PollType {
  YES_NO          // O, X
  LIKE_DISLIKE    // 좋아요, 싫어요
  MULTIPLE_CHOICE // 여러 선택지
}

enum PollCategory {
  IT_DIGITAL
  PET
  TRAVEL_PLACE
  GAME_HOBBY
  SPORTS_HEALTH
  ENTERTAINMENT
  FASHION_BEAUTY
  DAILY_LIFE
  EDUCATION_CULTURE
  FOOD_RESTAURANT
  LIFE_PARENTING
}

enum ResultMode {
  IMMEDIATE // 즉시 공개
  AFTER_VOTE // 투표 후 공개
  AFTER_END // 종료 후 공개
  PRIVATE // 비공개
}