model MissionCompletion {
  id            String           @id @default(cuid())
  title         String
  description   String
  imageUrl      String?          @map("image_url")
  minScoreRatio Int?             @map("min_score_ratio")
  maxScoreRatio Int?             @map("max_score_ratio")
  links         CompletionLink[]

  missionId String  @map("mission_id")
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  actionsPointingHere Action[]                          @relation("ActionToCompletion")
  optionsPointingHere ActionOption[]                    @relation("OptionToCompletion")
  selectedByResponses MissionResponse[]                 @relation("SelectedCompletion")
  stats               MissionCompletionStat[]
  inferenceCaches     MissionCompletionInferenceCache[]

  imageFileUploadId String?     @map("image_file_upload_id")
  imageFileUpload   FileUpload? @relation(fields: [imageFileUploadId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([missionId])
  @@map("mission_completions")
}
