model Action {
  id            String         @id @default(cuid())
  title         String
  description   String?
  imageUrl      String?        @map("image_url")
  type          ActionType
  order         Int
  maxSelections Int?           @map("max_selections")
  missionId     String?        @map("mission_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  answers       ActionAnswer[]
  options       ActionOption[]
  mission       Mission?       @relation(fields: [missionId], references: [id], onDelete: Cascade)

  imageFileUploadId String?     @unique @map("image_file_upload_id")
  imageFileUpload   FileUpload? @relation("ActionImage", fields: [imageFileUploadId], references: [id])

  @@index([missionId])
  @@map("actions")
}

enum ActionType {
  MULTIPLE_CHOICE
  SCALE
  RATING
  TAG
  SUBJECTIVE
  IMAGE
}
