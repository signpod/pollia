model Banner {
  id                String      @id @default(cuid())
  title             String
  subtitle          String?
  imageUrl          String      @map("image_url")
  order             Int         @default(0)
  imageFileUploadId String?     @unique @map("image_file_upload_id")
  imageFileUpload   FileUpload? @relation("BannerImage", fields: [imageFileUploadId], references: [id])
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("banners")
}
