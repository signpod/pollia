model User {
  id    String @id
  email String @unique
  name  String

  polls         Poll[]         @relation("PollCreator")
  votes         Vote[]
  pollLikes     PollLike[]
  pollBookmarks PollBookmark[]
  fileUploads   FileUpload[]   @relation("FileUploader")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
