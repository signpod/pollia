model User {
  id        String   @id
  email     String   @unique
  name      String
  phone     String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fileUploads      FileUpload[]
  missionResponses MissionResponse[]
  missions         Mission[]

  trackingActionEntries   TrackingActionEntry[]
  trackingActionResponses TrackingActionResponse[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}
