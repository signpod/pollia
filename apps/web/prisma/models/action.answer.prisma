model ActionAnswer {
  id         String   @id @default(cuid())
  actionId   String   @map("action_id")
  responseId String   @map("response_id")
  createdAt  DateTime @default(now()) @map("created_at")

  textAnswer    String?    @map("text_answer")
  scaleAnswer   Int?       @map("scale_answer")
  booleanAnswer Boolean?   @map("boolean_answer")
  dateAnswers   DateTime[] @map("date_answers")

  action   Action          @relation(fields: [actionId], references: [id], onDelete: Cascade)
  response MissionResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  fileUploads FileUpload[]
  options     ActionOption[]

  @@unique([responseId, actionId])
  @@index([actionId])
  @@index([responseId])
  @@map("action_answers")
}
