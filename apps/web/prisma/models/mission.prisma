model Mission {
  id               String      @id @default(cuid())
  title            String
  description      String?
  imageUrl         String?     @map("image_url")
  brandLogoUrl     String?     @map("brand_logo_url")
  estimatedMinutes Int?        @map("estimated_minutes")
  deadline         DateTime?
  isActive         Boolean     @default(true) @map("is_active")
  maxParticipants  Int?        @map("max_participants")
  creatorId        String      @map("creator_id")
  rewardId         String?     @map("reward_id")
  eventId          String?     @map("event_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  target           String?
  type             MissionType @default(GENERAL)
  password         String?

  questions  Action[]
  responses  MissionResponse[]
  completion MissionCompletion?
  creator    User               @relation(fields: [creatorId], references: [id])
  reward     Reward?            @relation(fields: [rewardId], references: [id])
  event      Event?             @relation(fields: [eventId], references: [id])
  notionPage MissionNotionPage?

  imageFileUploadId     String?     @map("image_file_upload_id")
  imageFileUpload       FileUpload? @relation("MissionImage", fields: [imageFileUploadId], references: [id])
  brandLogoFileUploadId String?     @map("brand_logo_file_upload_id")
  brandLogoFileUpload   FileUpload? @relation("MissionBrandLogo", fields: [brandLogoFileUploadId], references: [id])

  trackingActionEntries   TrackingActionEntry[]
  trackingActionResponses TrackingActionResponse[]

  @@index([creatorId])
  @@index([isActive])
  @@index([rewardId])
  @@index([eventId])
  @@map("missions")
}

enum MissionType {
  GENERAL
  EXPERIENCE_GROUP
}
