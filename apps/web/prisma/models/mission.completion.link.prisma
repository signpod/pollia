model CompletionLink {
  id                  String            @id @default(cuid())
  name                String
  url                 String
  imageUrl            String?           @map("image_url")
  order               Int
  missionCompletionId String            @map("mission_completion_id")
  missionCompletion   MissionCompletion @relation(fields: [missionCompletionId], references: [id], onDelete: Cascade)
  fileUploadId        String?           @map("file_upload_id")
  fileUpload          FileUpload?       @relation(fields: [fileUploadId], references: [id])
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([missionCompletionId])
  @@map("completion_links")
}
