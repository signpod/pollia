model FileUpload {
  id               String     @id @default(cuid())
  userId           String     @map("user_id")
  originalFileName String     @map("original_file_name")
  filePath         String     @map("file_path")
  publicUrl        String     @map("public_url")
  fileSize         Int        @map("file_size")
  mimeType         String     @map("mime_type")
  bucket           String     @default("pollia-images")
  status           FileStatus @default(TEMPORARY)
  createdAt        DateTime   @default(now()) @map("created_at")
  confirmedAt      DateTime?  @map("confirmed_at")

  actionOptions      ActionOption[] @relation("ActionOptionImage")
  missionImages      Mission[]      @relation("MissionImage")
  missionBrandLogos  Mission[]      @relation("MissionBrandLogo")
  actionImages       Action[]       @relation("ActionImage")
  actionAnswerImages ActionAnswer[] @relation("ActionAnswerImage")
  rewardImages       Reward[]       @relation("RewardImage")

  user User @relation("FileUploader", fields: [userId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("file_uploads")
}

enum FileStatus {
  TEMPORARY
  CONFIRMED
}
