model ActionAnswer {
    id       String        @id @default(cuid())
    optionId String?       @map("option_id")
    option   ActionOption? @relation(fields: [optionId], references: [id], onDelete: Cascade)

    textAnswer  String? @map("text_answer")
    scaleAnswer Int?    @map("scale_answer")

    actionId String @map("action_id")
    action   Action @relation(fields: [actionId], references: [id], onDelete: Cascade)

    responseId String          @map("response_id")
    response   MissionResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([responseId, actionId, optionId])
    @@index([actionId])
    @@index([responseId])
    @@map("action_answers")
}
