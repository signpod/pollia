model SurveyQuestionAnswer {
    id       String                @id @default(cuid())
    optionId String?               @map("option_id")
    option   SurveyQuestionOption? @relation(fields: [optionId], references: [id], onDelete: Cascade)

    textAnswer  String? @map("text_answer")
    scaleAnswer Int?    @map("scale_answer")

    questionId String         @map("question_id")
    question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

    responseId String         @map("response_id")
    response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")

    @@unique([responseId, questionId, optionId])
    @@index([questionId])
    @@index([responseId])
    @@map("survey_question_answers")
}
