model Poll {
  id              String       @id @default(cuid())
  title           String
  description     String?
  imageUrl        String?      @map("image_url")
  type            PollType
  category        PollCategory
  startDate       DateTime
  endDate         DateTime?
  isIndefinite    Boolean      @default(false)
  maxSelections   Int?
  showResultsMode ResultMode   @default(IMMEDIATE)
  isPublic        Boolean      @default(true)
  creatorId       String

  creator   User           @relation("PollCreator", fields: [creatorId], references: [id])
  options   PollOption[]
  votes     Vote[]
  likes     PollLike[]
  bookmarks PollBookmark[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([type])
  @@index([startDate, endDate])
  @@map("polls")
}

enum PollType {
  YES_NO
  LIKE_DISLIKE
  MULTIPLE_CHOICE
}

enum PollCategory {
  IT_DIGITAL
  PET
  TRAVEL_PLACE
  GAME_HOBBY
  SPORTS_HEALTH
  ENTERTAINMENT
  FASHION_BEAUTY
  DAILY_LIFE
  EDUCATION_CULTURE
  FOOD_RESTAURANT
  LIFE_PARENTING
}

enum ResultMode {
  IMMEDIATE
  AFTER_VOTE
  AFTER_END
  PRIVATE
}
