# Database (Prisma + Supabase)
# 런타임: 트랜잭션 모드 풀러(6543)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres
# 마이그레이션: 세션 모드(5432). prisma migrate 시 사용
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres

# App URL (OG/트위터 이미지 절대 경로용. 미설정 시 localhost:3000)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Supabase (Auth, Storage 등)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_SECRET_KEY=

# Kakao (로그인/공유). Client Secret은 카카오 개발자 콘솔에서 발급 후 필수 설정
NEXT_PUBLIC_KAKAO_JS_KEY=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# Cron / API 보안
CRON_SECRET=
REVALIDATION_SECRET=

# Notion (미션 리포트, 선택)
MISSION_REPORT_NOTION_API_KEY=
MISSION_REPORT_NOTION_DATABASE_ID=

# 미션 비밀번호 암복호화
MISSION_PASSWORD_SECRET_KEY=
