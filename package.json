{
  "name": "pollia",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:clean": "yarn clean:cache && turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean:cache": "rm -rf .turbo apps/*/.next apps/*/out apps/storybook/storybook-static"
  },
  "devDependencies": {
    "corepack": "^0.29.4",
    "eslint": "^9.34.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "yarn@4.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
