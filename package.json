{
  "name": "pollia",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:clean": "yarn clean:cache && turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "check-types": "turbo run check-types",
    "clean:cache": "rm -rf .turbo apps/*/.next apps/*/out apps/storybook/storybook-static"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "corepack": "^0.29.4",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "yarn@4.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "zod": "^4.1.11"
  }
}
