## Mutation Hooks (데이터 변경)

### 1. 기본 Mutation Hook

```typescript
"use client"; // ✅ 클라이언트 컴포넌트 명시

import { useMutation } from "@tanstack/react-query";
import { createData } from "@/actions/domain";
import type { CreateDataRequest, CreateDataResponse } from "@/types/dto";

interface UseCreateDataOptions {
  onSuccess?: (data: CreateDataResponse) => void;
  onError?: (error: Error) => void;
}

export function useCreateData(options: UseCreateDataOptions = {}) {
  return useMutation({
    mutationFn: async (
      payload: CreateDataRequest
    ): Promise<CreateDataResponse> => {
      return createData(payload);
    },
    onSuccess: (data) => {
      options.onSuccess?.(data);
    },
    onError: (error) => {
      console.error("❌ 데이터 생성 실패:", error);
      options.onError?.(error as Error);
    },
  });
}
```

**필수 요소:**

- `"use client"` directive
- Options 인터페이스로 콜백 받기
- 타입 명시 (`CreateDataRequest`, `CreateDataResponse`)
- onSuccess, onError 핸들링

### 2. Optimistic Update Pattern

```typescript
import { useMutation, useQueryClient } from "@tanstack/react-query";
import { toggleLike } from "@/actions/poll";
import { pollQueryKeys } from "@/constants/queryKeys/pollQueryKeys";
import { toast } from "@repo/ui/components";
import type { GetPollUserStatusResponse } from "@/types/dto";

interface LikeMutationContext {
  previousUserStatus: GetPollUserStatusResponse | undefined;
  pollId: string;
  optimisticUpdate: boolean;
}

const LIKE_MESSAGES = {
  success: {
    like: "좋아요를 눌렀어요.",
    cancel: "좋아요를 취소했어요.",
  },
  error: "좋아요 처리 중 오류가 발생했어요.",
} as const;

export const useLike = (pollId: string) => {
  const queryClient = useQueryClient();

  const likeMutation = useMutation<
    ToggleLikeResponse,
    Error,
    void,
    LikeMutationContext // ✅ Context 타입 정의
  >({
    mutationFn: async () => {
      return await toggleLike(pollId);
    },

    // ✅ 1. Optimistic Update
    onMutate: async () => {
      // 진행 중인 쿼리 취소
      await queryClient.cancelQueries({
        queryKey: pollQueryKeys.userPollStatus(pollId),
      });

      // 이전 데이터 백업
      const previousUserStatus =
        queryClient.getQueryData<GetPollUserStatusResponse>(
          pollQueryKeys.userPollStatus(pollId)
        );

      // Optimistic Update
      queryClient.setQueryData<GetPollUserStatusResponse>(
        pollQueryKeys.userPollStatus(pollId),
        (oldData) => {
          if (!oldData) return oldData;
          return {
            ...oldData,
            isLiked: !oldData.isLiked,
          };
        }
      );

      // Context 반환 (롤백용)
      return {
        previousUserStatus,
        pollId,
        optimisticUpdate: true,
      };
    },

    // ✅ 2. 성공 시 처리
    onSuccess: () => {
      // 관련 쿼리 무효화
      queryClient.invalidateQueries({
        queryKey: pollQueryKeys.userPollStatus(pollId),
      });
      queryClient.invalidateQueries({
        queryKey: pollQueryKeys.likedPolls(),
      });

      toast.success(
        isLiked ? LIKE_MESSAGES.success.like : LIKE_MESSAGES.success.cancel
      );
    },

    // ✅ 3. 실패 시 롤백
    onError: (_, _variables, context) => {
      if (context?.previousUserStatus) {
        queryClient.setQueryData<GetPollUserStatusResponse>(
          pollQueryKeys.userPollStatus(pollId),
          context.previousUserStatus
        );
      }
      toast.error(LIKE_MESSAGES.error);
    },
  });

  // ✅ 4. 현재 상태 조회
  const userStatus = queryClient.getQueryData<GetPollUserStatusResponse>(
    pollQueryKeys.userPollStatus(pollId)
  );
  const isLiked = userStatus?.isLiked || false;

  // ✅ 5. 명확한 인터페이스 반환
  return {
    isLiked,
    isProcessing: likeMutation.isPending,
    handleLike: likeMutation.mutate,
    error: likeMutation.error,
    isError: likeMutation.isError,
  };
};

export type UseLikeReturn = ReturnType<typeof useLike>;
```

**Optimistic Update 체크리스트:**

- [ ] `onMutate`에서 `cancelQueries`로 진행 중인 쿼리 취소
- [ ] 이전 데이터 백업 (롤백용)
- [ ] `setQueryData`로 즉시 UI 업데이트
- [ ] Context에 롤백 정보 저장
- [ ] `onSuccess`에서 `invalidateQueries`
- [ ] `onError`에서 이전 데이터로 롤백
- [ ] 사용자 피드백 (toast)

### 3. 복잡한 Mutation (다중 작업)

```typescript
export function useImageUpload(options: UseImageUploadOptions = {}) {
  const [uploadProgress, setUploadProgress] =
    useState<ImageUploadProgress | null>(null);

  // ✅ 여러 mutation 정의
  const uploadMutation = useMutation({
    mutationFn: async (file: File): Promise<UploadedImage> => {
      // ... 복잡한 로직
    },
    onSuccess: (data) => {
      console.log("✅ 이미지 업로드 성공:", data);
      options.onSuccess?.(data);
    },
    onError: (error) => {
      console.error("❌ 이미지 업로드 실패:", error);
      options.onError?.(error as Error);
    },
  });

  const deleteMutation = useMutation({
    mutationFn: (request: DeleteImageRequest) => deleteImage(request),
    onSuccess: () => console.log("✅ 이미지 삭제 성공"),
    onError: (error) => console.error("❌ 이미지 삭제 실패:", error),
  });

  const confirmMutation = useMutation({
    mutationFn: (request: ConfirmFileRequest) => confirmFile(request),
    onSuccess: () => console.log("✅ 파일 확정 성공"),
    onError: (error) => console.error("❌ 파일 확정 실패:", error),
  });

  // ✅ 명확하게 그룹화된 반환값
  return {
    // 업로드
    upload: uploadMutation.mutate,
    uploadAsync: uploadMutation.mutateAsync,
    isUploading: uploadMutation.isPending,
    uploadProgress,
    uploadError: uploadMutation.error,

    // 삭제
    deleteImage: deleteMutation.mutate,
    deleteImageAsync: deleteMutation.mutateAsync,
    isDeleting: deleteMutation.isPending,
    deleteError: deleteMutation.error,

    // 확정 처리
    confirmFile: confirmMutation.mutate,
    confirmFileAsync: confirmMutation.mutateAsync,
    isConfirming: confirmMutation.isPending,
    confirmError: confirmMutation.error,

    reset: () => {
      uploadMutation.reset();
      deleteMutation.reset();
      confirmMutation.reset();
      setUploadProgress(null);
    },
  };
}
```

## Query Keys 관리

### 파일 구조

```
src/constants/queryKeys/
├── pollQueryKeys.ts
├── surveyQueryKeys.ts
└── userQueryKeys.ts
```

### Query Keys 정의 패턴

```typescript
// pollQueryKeys.ts
export const pollQueryKeys = {
  // 단일 리소스
  poll: (pollId: string) => ["poll", pollId] as const,

  // 관계 데이터
  pollResults: (pollId: string) => ["poll-results", pollId] as const,
  userVoteStatus: (pollId: string) => ["user-vote-status", pollId] as const,

  // 리스트 (optional 매개변수)
  userPolls: (userId?: string) =>
    userId ? (["user-polls", userId] as const) : (["user-polls"] as const),

  bookmarkedPolls: (userId?: string) =>
    userId
      ? (["bookmarked-polls", userId] as const)
      : (["bookmarked-polls"] as const),

  // 전체 무효화용
  all: () => ["poll"] as const,
} as const;

export type PollQueryKeys = typeof pollQueryKeys;
```

**규칙:**

- [ ] 모든 queryKey는 별도 파일로 관리
- [ ] 함수로 정의하여 동적 매개변수 지원
- [ ] `as const`로 타입 안정성 확보
- [ ] optional 매개변수는 삼항 연산자로 처리
- [ ] 타입 export

### Query Key 네이밍 컨벤션

```typescript
✅ poll: (id) => ["poll", id]                    # 단일 리소스
✅ pollResults: (id) => ["poll-results", id]     # 파생 데이터
✅ userPolls: (userId) => ["user-polls", userId] # 사용자별 목록
✅ all: () => ["poll"]                           # 전체 무효화

❌ ["poll", id]                                  # 함수로 감싸지 않음
❌ getPoll: (id) => ["poll", id]                 # get 프리픽스 불필요
```

