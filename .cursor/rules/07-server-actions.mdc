- [ ] `{ data: ... }` 형식으로 반환
- [ ] select/include로 필요한 데이터만 조회
- [ ] orderBy로 정렬 (목록 조회 시)

### 수정 액션

- [ ] `requireAuth()`로 사용자 인증
- [ ] 권한 확인 (작성자만 수정 가능)
- [ ] 리소스 존재 확인 (404)
- [ ] 권한 없을 시 403 에러
- [ ] Validation 로직

### 삭제 액션

- [ ] `requireAuth()`로 사용자 인증
- [ ] 권한 확인 (작성자만 삭제 가능)
- [ ] 리소스 존재 확인 (404)
- [ ] 권한 없을 시 403 에러
- [ ] 삭제 성공 메시지

### 토글 액션

- [ ] `requireAuth()`로 사용자 인증
- [ ] 리소스 존재 확인 (404)
- [ ] 현재 상태 확인
- [ ] 토글 처리
- [ ] 결과 상태 반환 (`isLiked`, `isBookmarked` 등)

## 예제: Survey Domain Action 생성

```typescript
// 1. 조회 액션
// actions/survey/read.ts
"use server";

import { requireAuth } from "@/actions/common/auth";
import prisma from "@/database/utils/prisma/client";
import type { GetSurveyResponse } from "@/types/dto/survey";

export async function getSurvey(surveyId: string): Promise<GetSurveyResponse> {
  try {
    const survey = await prisma.survey.findUnique({
      where: { id: surveyId },
      include: {
        creator: {
          select: {
            id: true,
            name: true,
          },
        },
        questions: {
          include: {
            options: {
              select: {
                id: true,
                description: true,
                order: true,
              },
            },
          },
        },
      },
    });

    if (!survey) {
      const error = new Error("설문조사를 찾을 수 없습니다.");
      error.cause = 404;
      throw error;
    }

    return { data: survey };
  } catch (error) {
    if (error instanceof Error && error.cause) {
      throw error;
    }
    const serverError = new Error("설문조사를 불러올 수 없습니다.");
    serverError.cause = 500;
    throw serverError;
  }
}

// 2. 생성 액션
// actions/survey/create.ts
("use server");

import { requireAuth } from "@/actions/common/auth";
import prisma from "@/database/utils/prisma/client";
import type {
  CreateSurveyRequest,
  CreateSurveyResponse,
} from "@/types/dto/survey";

export async function createSurvey(
  request: CreateSurveyRequest
): Promise<CreateSurveyResponse> {
  try {
    const user = await requireAuth();

    const validationError = validateSurveyRequest(request);
    if (validationError) {
      const error = new Error(validationError);
      error.cause = 400;
      throw error;
    }

    const survey = await prisma.$transaction(async (tx) => {
      const createdSurvey = await tx.survey.create({
        data: {
          title: request.title,
          description: request.description,
          creatorId: user.id,
        },
      });

      // 질문 생성
      for (const question of request.questions) {
        await tx.surveyQuestion.create({
          data: {
            surveyId: createdSurvey.id,
            title: question.title,
            type: question.type,
            order: question.order,
            options: {
              createMany: {
                data: question.options.map((opt) => ({
                  description: opt.description,
                  order: opt.order,
                })),
              },
            },
          },
        });
      }

      return createdSurvey;
    });

    return {
      data: {
        id: survey.id,
        title: survey.title,
        createdAt: survey.createdAt,
      },
    };
  } catch (error) {
    if (error instanceof Error && error.cause) {
      throw error;
    }
    const serverError = new Error("설문조사 생성 중 오류가 발생했습니다.");
    serverError.cause = 500;
    throw serverError;
  }
}

function validateSurveyRequest(request: CreateSurveyRequest): string | null {
  if (!request.title || request.title.trim().length === 0) {
    return "제목은 필수입니다.";
  }
  if (request.questions.length === 0) {
    return "최소 1개 이상의 질문이 필요합니다.";
  }
  return null;
}

// 3. Re-export
// actions/survey/index.ts
export { createSurvey } from "./create";
export { getSurvey } from "./read";
```

이 규칙을 따르면 일관성 있고 유지보수하기 쉬운 Server Actions를 작성할 수 있습니다.
