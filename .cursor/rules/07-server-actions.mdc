## Server Action 기본 구조

### 1. 조회 액션 (Read)

```typescript
"use server";

import { requireAuth } from "@/actions/common/auth";
import prisma from "@/database/utils/prisma/client";
import type { GetPollResponse } from "@/types/dto";

export async function getPoll(pollId: string): Promise<GetPollResponse> {
  try {
    const poll = await prisma.poll.findUnique({
      where: { id: pollId },
      include: {
        creator: {
          select: {
            id: true,
            name: true,
          },
        },
        options: {
          select: {
            id: true,
            description: true,
            imageUrl: true,
            _count: {
              select: {
                votes: true,
              },
            },
          },
        },
        _count: {
          select: {
            votes: true,
            likes: true,
            bookmarks: true,
          },
        },
      },
    });

    if (!poll) {
      const error = new Error("투표를 찾을 수 없습니다.");
      error.cause = 404;
      throw error;
    }

    return { data: poll };
  } catch (error) {
    if (error instanceof Error && error.cause) {
      throw error;
    }
    const serverError = new Error("투표를 불러올 수 없습니다.");
    serverError.cause = 500;
    throw serverError;
  }
}
```

**필수 요소:**

- [ ] `"use server"` directive
- [ ] DTO 타입 정의 및 사용
- [ ] try-catch 에러 처리
- [ ] error.cause로 HTTP 상태 코드 전달
- [ ] 일관된 응답 형식 `{ data: ... }`
- [ ] 인증 필요 시 `requireAuth()` 사용
- [ ] 리소스 없을 시 404 에러

### 2. 생성 액션 (Create)

```typescript
"use server";

import { requireAuth } from "@/actions/common/auth";
import prisma from "@/database/utils/prisma/client";
import type { CreatePollRequest, CreatePollResponse } from "@/types/dto";

export async function createPoll(
  request: CreatePollRequest
): Promise<CreatePollResponse> {
  try {
    const user = await requireAuth();

    // 1. Validation
    const validationError = validatePollRequest(request);
    if (validationError) {
      const error = new Error(validationError);
      error.cause = 400;
      throw error;
    }

    // 2. Transaction으로 복잡한 생성 로직 처리
    const poll = await prisma.$transaction(async (tx) => {
      const createdPoll = await tx.poll.create({
        data: {
          title: request.title,
          description: request.description,
          type: request.type,
          category: request.category,
          creatorId: user.id,
        },
      });

      // 관련 데이터 생성
      await tx.pollOption.createMany({
        data: request.options.map((option) => ({
          pollId: createdPoll.id,
          description: option.description,
          order: option.order,
        })),
      });

      return createdPoll;
    });

    return {
      data: {
        id: poll.id,
        title: poll.title,
        type: poll.type,
        category: poll.category,
        createdAt: poll.createdAt,
      },
    };
  } catch (error) {
    if (error instanceof Error && error.cause) {
      throw error;
    }
    const serverError = new Error("폴 생성 중 오류가 발생했습니다.");
    serverError.cause = 500;
    throw serverError;
  }
}

// ✅ Validation 함수 분리
function validatePollRequest(request: CreatePollRequest): string | null {
  if (!request.title || request.title.trim().length === 0) {
    return "제목은 필수입니다.";
  }
  if (request.title.length > 100) {
    return "제목은 100자를 초과할 수 없습니다.";
  }
  // ... 추가 검증
  return null;
}
```

**필수 요소:**

- [ ] `requireAuth()`로 사용자 인증
- [ ] Validation 로직 분리
- [ ] `$transaction`으로 복잡한 로직 처리
- [ ] 400 에러 (잘못된 요청)
- [ ] 생성된 리소스의 주요 정보만 반환

### 3. 토글 액션 (Toggle)

```typescript
"use server";

import { requireAuth } from "@/actions/common/auth";
import prisma from "@/database/utils/prisma/client";

export async function toggleLikePoll(pollId: string) {
  try {
    const user = await requireAuth();

    // 1. 리소스 존재 확인
    const poll = await prisma.poll.findUnique({
      where: { id: pollId },
      select: { id: true },
    });

    if (!poll) {
      const error = new Error("존재하지 않는 투표입니다.");
      error.cause = 404;
      throw error;
    }

    // 2. 현재 상태 확인
    const existingLike = await prisma.pollLike.findUnique({
      where: {
        pollId_userId: {
          pollId: pollId,
          userId: user.id,
        },
      },
    });

    let isLiked: boolean;

    // 3. 토글 처리
    if (existingLike) {
      await prisma.pollLike.delete({
        where: {
          pollId_userId: {
            pollId: pollId,
            userId: user.id,
          },
        },
      });
      isLiked = false;
    } else {
      await prisma.pollLike.create({
        data: {
          pollId: pollId,
          userId: user.id,
        },
      });
      isLiked = true;
    }

    return {
      isLiked,
      message: isLiked
        ? "좋아요가 추가되었습니다."
        : "좋아요가 취소되었습니다.",
    };
  } catch (error) {
    console.error("❌ 좋아요 토글 에러:", error);
    if (error instanceof Error && error.cause) {
      throw error;
    }
    const serverError = new Error("좋아요 처리 중 오류가 발생했습니다.");
    serverError.cause = 500;
    throw serverError;
  }
}
```

**필수 요소:**

- [ ] 리소스 존재 확인 (404)
- [ ] 현재 상태 확인
- [ ] 토글 로직
- [ ] 결과 상태 반환 (`isLiked`)
- [ ] console.error로 에러 로깅

### 4. 삭제 액션 (Delete)

```typescript
"use server";

import { requireAuth } from "@/actions/common/auth";
import prisma from "@/database/utils/prisma/client";

export async function deletePoll(pollId: string) {
  try {
    const user = await requireAuth();

    // 1. 권한 확인
    const poll = await prisma.poll.findUnique({
      where: { id: pollId },
      select: { id: true, creatorId: true },
    });

    if (!poll) {
      const error = new Error("존재하지 않는 투표입니다.");
      error.cause = 404;
      throw error;
    }

    if (poll.creatorId !== user.id) {
      const error = new Error("삭제 권한이 없습니다.");
      error.cause = 403;
      throw error;
    }

    // 2. 삭제 (onDelete: Cascade로 관련 데이터 자동 삭제)
    await prisma.poll.delete({
      where: { id: pollId },
    });

    return {
      message: "투표가 삭제되었습니다.",
    };
  } catch (error) {
    console.error("❌ 투표 삭제 에러:", error);
    if (error instanceof Error && error.cause) {
      throw error;
    }
    const serverError = new Error("투표 삭제 중 오류가 발생했습니다.");
    serverError.cause = 500;
    throw serverError;
  }
}
```

**필수 요소:**

- [ ] 권한 확인 (403)
- [ ] 리소스 존재 확인 (404)
- [ ] 삭제 성공 메시지

## 인증 처리

### requireAuth 함수

````typescript
// actions/common/auth.ts
import { createClient as createServerSupabaseClient } from "@/database/utils/supabase/server";
import type { User } from "@supabase/supabase-js";

/**
 * Server Action에서 인증된 사용자를 가져옵니다.
 * 인증되지 않은 경우 401 에러를 throw합니다.
 *
 * @throws {Error} 로그인이 필요한 경우 (error.cause = 401)
 * @returns {Promise<User>} 인증된 사용자 객체
 *
 * @example
 * ```typescript
 * export async function myServerAction() {
 *   try {
 *     const user = await requireAuth();
 *     // user.id 사용 가능
 *   } catch (error) {
 *     if (error instanceof Error && error.cause === 401) {
 *       // 인증 에러 처리
 *     }
 *   }
 * }
 * ```
 */
export async function requireAuth(): Promise<User> {
  const supabase = await createServerSupabaseClient();
  const {
    data: { user },
    error: authError,
  } = await supabase.auth.getUser();

  if (authError || !user) {
    const error = new Error("로그인이 필요합니다.");
    error.cause = 401;
    throw error;
  }

  return user;
}
````

**사용:**

```typescript
export async function myServerAction() {
  const user = await requireAuth(); // ✅ 인증 필수
  // user.id 사용
}

export async function publicAction() {
  // requireAuth() 호출 안 함 ✅ 인증 불필요
}
```

## 에러 처리

### HTTP 상태 코드 패턴

```typescript
// 400: Bad Request (잘못된 요청)
const error = new Error("제목은 필수입니다.");
error.cause = 400;
throw error;

// 401: Unauthorized (인증 필요)
const error = new Error("로그인이 필요합니다.");
error.cause = 401;
throw error;

// 403: Forbidden (권한 없음)
const error = new Error("삭제 권한이 없습니다.");
error.cause = 403;
throw error;

// 404: Not Found (리소스 없음)
const error = new Error("투표를 찾을 수 없습니다.");
error.cause = 404;
throw error;

// 409: Conflict (중복)
const error = new Error("이미 좋아요를 누른 투표입니다.");
error.cause = 409;
throw error;

// 500: Internal Server Error (서버 오류)
const error = new Error("투표 생성 중 오류가 발생했습니다.");
error.cause = 500;
throw error;
```

### 에러 처리 표준 패턴

```typescript
export async function myServerAction() {
  try {
    // 비즈니스 로직
  } catch (error) {
    console.error("❌ 에러 설명:", error); // ✅ 에러 로깅

    // 이미 cause가 설정된 에러는 그대로 throw
    if (error instanceof Error && error.cause) {
      throw error;
    }

    // 예상치 못한 에러는 500으로 처리
    const serverError = new Error("작업 중 오류가 발생했습니다.");
    serverError.cause = 500;
    throw serverError;
  }
}
```

## DTO 타입 정의

### Request/Response 타입

```typescript
// types/dto/poll.ts

// Request
export interface CreatePollRequest {
  title: string;
  description?: string;
  imageUrl?: string;
  type: PollType;
  category: PollCategory;
  startDate: Date;
  endDate?: Date;
  isIndefinite?: boolean;
  maxSelections?: number;
  options: {
    description: string;
    imageUrl?: string;
    link?: string;
    order: number;
  }[];
}

// Response
export interface CreatePollResponse {
  data: {
    id: string;
    title: string;
    type: PollType;
    category: PollCategory;
    createdAt: Date;
  };
}

export interface GetPollResponse {
  data: Poll & {
    creator: {
      id: string;
      name: string;
    };
    options: Array<
      PollOption & {
        _count: {
          votes: number;
        };
      }
    >;
    _count: {
      votes: number;
      likes: number;
      bookmarks: number;
    };
  };
}
```

**규칙:**

- Request는 `{도메인}{동작}Request` 패턴
- Response는 `{도메인}{동작}Response` 패턴
- Response는 항상 `{ data: ... }` 구조

## Validation

### 1. Zod Schema 활용

```typescript
import { binaryPollSchema } from "@/schemas/binaryPollSchema";

function validatePollRequestWithClientSchema(
  request: CreatePollRequest
): string | null {
  try {
    const formData = {
      category: request.category,
      title: request.title,
      description: request.description || "",
      // ...
    };

    const result = binaryPollSchema.safeParse(formData);
    if (!result.success) {
      return result.error.issues[0]?.message || "유효성 검사에 실패했습니다.";
    }

    return null;
  } catch {
    return "유효성 검사 중 오류가 발생했습니다.";
  }
}
```

### 2. 수동 Validation

```typescript
function validatePollRequest(request: CreatePollRequest): string | null {
  if (!request.title || request.title.trim().length === 0) {
    return "제목은 필수입니다.";
  }

  if (request.title.length > 100) {
    return "제목은 100자를 초과할 수 없습니다.";
  }

  if (request.options.length < 2) {
    return "최소 2개 이상의 선택지가 필요합니다.";
  }

  return null; // 검증 통과
}
```

**사용:**

```typescript
const validationError = validatePollRequest(request);
if (validationError) {
  const error = new Error(validationError);
  error.cause = 400;
  throw error;
}
```

## Transaction 사용

### 복잡한 생성 로직

```typescript
const result = await prisma.$transaction(async (tx) => {
  // 1. 메인 리소스 생성
  const created = await tx.poll.create({
    data: {
      /* ... */
    },
  });

  // 2. 관련 리소스 생성
  await tx.pollOption.createMany({
    data: options.map((opt) => ({
      pollId: created.id,
      description: opt.description,
      order: opt.order,
    })),
  });

  // 3. 파일 상태 업데이트
  if (fileUploadId) {
    await tx.fileUpload.update({
      where: { id: fileUploadId },
      data: {
        status: FileStatus.CONFIRMED,
        relatedEntityId: created.id,
      },
    });
  }

  return created;
});
```

### 토글 로직에서는 불필요

```typescript
// ✅ 단순 토글은 transaction 불필요
if (existingLike) {
  await prisma.pollLike.delete({ where: { id: existingLike.id } });
} else {
  await prisma.pollLike.create({ data: { pollId, userId } });
}

// ❌ 불필요한 transaction
await prisma.$transaction(async (tx) => {
  if (existingLike) {
    await tx.pollLike.delete({ where: { id: existingLike.id } });
  }
});
```

